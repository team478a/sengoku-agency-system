{
  "name": "team478a/sengoku-agency-system",
  "description": "Sengoku agency system modular monolith foundation",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.12"
  },
  "autoload": {
    "psr-4": {
      "SenNoKuni\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SenNoKuni\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "php scripts/lint-php.php",
    "test": "phpunit",
    "analyse": "phpstan analyse --memory-limit=512M"
  },
  "config": {
    "sort-packages": true
  }
}

